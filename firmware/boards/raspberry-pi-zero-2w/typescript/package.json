  "description": "Raspberry Pi Zero 2W cyberdeck controller - interfaces with Meshtastic radio, LTE cellular, HID input, and display",
  "type": "module",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
